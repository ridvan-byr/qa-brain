{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build QA Cortex core",
      "type": "shell",
      "command": "npm",
      "args": [
        "run",
        "build",
        "--prefix",
        "${workspaceFolder}/../.."
      ],
      "problemMatcher": "$tsc"
    },
    {
      "label": "compile VS Code client",
      "type": "npm",
      "script": "compile",
      "problemMatcher": "$tsc"
    },
    {
      "label": "build QA Cortex VS Code Client",
      "dependsOrder": "sequence",
      "dependsOn": [
        "build QA Cortex core",
        "compile VS Code client"
      ],
      "problemMatcher": []
    }
  ]
}
