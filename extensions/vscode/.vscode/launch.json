{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run QA Cortex Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/out/**/*.js"
      ],
      "preLaunchTask": "build QA Cortex VS Code Client"
    }
  ]
}
